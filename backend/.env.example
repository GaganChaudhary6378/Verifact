# ═══════════════════════════════════════════════════════════════════
# VERIFACT BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys

# ═══════════════════════════════════════════════════════════════════
# LLM PROVIDERS
# ═══════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ═══════════════════════════════════════════════════════════════════
# WEB SEARCH & NEWS APIs
# ═══════════════════════════════════════════════════════════════════
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
NEWS_API_KEY=your_news_api_key_here

# ═══════════════════════════════════════════════════════════════════
# RERANKING
# ═══════════════════════════════════════════════════════════════════
COHERE_API_KEY=your_cohere_api_key_here

# ═══════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════
# EMBEDDING MODEL
# ═══════════════════════════════════════════════════════════════════
EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu

# ═══════════════════════════════════════════════════════════════════
# LLM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
PRIMARY_LLM=claude-3-5-sonnet-20241022
FALLBACK_LLM=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ═══════════════════════════════════════════════════════════════════
# RETRIEVAL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
TOP_K_RETRIEVAL=20
RERANK_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ═══════════════════════════════════════════════════════════════════
# SCORING THRESHOLDS
# ═══════════════════════════════════════════════════════════════════
SUPPORTED_SCORE_THRESHOLD=75
REFUTED_SCORE_THRESHOLD=-50
MIN_CONSENSUS_PERCENTAGE=70
MIN_SOURCES_COUNT=3
MIN_CONFIDENCE_THRESHOLD=60

# ═══════════════════════════════════════════════════════════════════
# RAGAS QUALITY GATES
# ═══════════════════════════════════════════════════════════════════
MIN_FAITHFULNESS=0.85
MIN_CONTEXT_PRECISION=0.75
MIN_ANSWER_CORRECTNESS=0.80
CACHE_MIN_FAITHFULNESS=0.80

# ═══════════════════════════════════════════════════════════════════
# CACHE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
CACHE_TTL_SECONDS=86400
CACHE_SIMILARITY_THRESHOLD=0.95

# ═══════════════════════════════════════════════════════════════════
# API SERVER
# ═══════════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════
# CORS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://*
